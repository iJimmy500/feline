#!/usr/bin/env bash
set -euo pipefail

BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
RESET='\033[0m'

REPO="iJimmy500/feline"
FLAG="$HOME/.feline/update_available"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    echo "Usage: feline update"
    echo ""
    echo "Check for and install the latest version of feline."
    exit 0
fi

echo ""
echo -e "${BOLD}feline update${RESET}"
echo ""

CURRENT=$(feline --version 2>/dev/null | awk '{print $2}')
if [[ -z "$CURRENT" ]]; then
    echo -e "${RED}Error:${RESET} Could not determine current version." >&2
    exit 1
fi

echo -e "Current version: ${CYAN}${CURRENT}${RESET}"
echo -e "Checking for updates..."
echo ""

LATEST=$(curl -fsSL --max-time 10 \
    "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null \
    | grep '"tag_name"' \
    | sed 's/.*"v\([^"]*\)".*/\1/')

if [[ -z "$LATEST" ]]; then
    echo -e "${RED}Error:${RESET} Could not reach GitHub. Check your connection." >&2
    exit 1
fi

if [[ "$LATEST" == "$CURRENT" ]]; then
    echo -e "${GREEN}You're already on the latest version (${CURRENT}).${RESET}"
    rm -f "$FLAG"
    exit 0
fi

echo -e "Latest version:  ${GREEN}${LATEST}${RESET}"
echo ""
echo -n -e "${BOLD}Install v${LATEST}? [y/n]:${RESET} "
read -r ANSWER

if [[ ! "$ANSWER" =~ ^[Yy]$ ]]; then
    echo ""
    echo -e "${DIM}Skipped.${RESET}"
    exit 0
fi

echo ""

TMP="$(mktemp -d)"
trap 'rm -rf "$TMP"' EXIT

TARBALL="feline-${LATEST}-macos.tar.gz"
BASE_URL="https://github.com/${REPO}/releases/download/v${LATEST}"

echo -e "${CYAN}Downloading feline ${LATEST}...${RESET}"
curl -fsSL --progress-bar "${BASE_URL}/${TARBALL}" -o "${TMP}/${TARBALL}"
curl -fsSL "${BASE_URL}/${TARBALL}.sha256" -o "${TMP}/${TARBALL}.sha256"

echo -e "${CYAN}Verifying...${RESET}"
EXPECTED=$(cat "${TMP}/${TARBALL}.sha256")
ACTUAL=$(shasum -a 256 "${TMP}/${TARBALL}" | awk '{print $1}')

if [[ "$EXPECTED" != "$ACTUAL" ]]; then
    echo -e "${RED}Error:${RESET} Checksum mismatch — download may be corrupt." >&2
    exit 1
fi

echo -e "  ${GREEN}✓${RESET}  checksum OK"
echo ""

tar -xzf "${TMP}/${TARBALL}" -C "$TMP"
bash "${TMP}/feline-${LATEST}-macos/install.sh"

rm -f "$FLAG"
