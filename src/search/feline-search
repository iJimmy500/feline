#!/usr/bin/env bash
set -euo pipefail

# macOS ships bash 3.2, which lacks features this script relies on
# (associative arrays, mapfile, ${var,,}). Re-exec under a newer bash if
# one is available (Homebrew installs one), otherwise explain.
if (( BASH_VERSINFO[0] < 4 )); then
    for _newer_bash in /opt/homebrew/bin/bash /usr/local/bin/bash; do
        [[ -x "$_newer_bash" ]] && exec "$_newer_bash" "$0" "$@"
    done
    echo "feline: this command needs bash 4+ (macOS ships 3.2). Install it with: brew install bash" >&2
    exit 1
fi

BOLD='\033[1m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
DIM='\033[2m'
RESET='\033[0m'

_SPIN_PID=""
spin_start() {
    local msg="${1:-}"
    local frames=('=^.^=~    ' '=^.^= ~   ' '=^.^=  ~  ' '=^.^=   ~ ' '=^.^=    ~' '=^.^=   ~ ' '=^.^=  ~  ' '=^.^= ~   ')
    # Ignore INT (ctrl-C is handled by the parent) but NOT TERM —
    # spin_stop kills this subshell with TERM; ignoring it would make
    # `wait` block forever and hang the whole command.
    ( trap '' INT
      local i=0
      while true; do
          printf "\r  ${PURPLE}${frames[$((i % ${#frames[@]}))]}${RESET}  ${DIM}${msg}${RESET}"
          sleep 0.1
          i=$(( i + 1 ))
      done ) &
    _SPIN_PID=$!
}
spin_stop() {
    [[ -n "${_SPIN_PID:-}" ]] || return 0
    kill "$_SPIN_PID" 2>/dev/null || true
    wait "$_SPIN_PID" 2>/dev/null || true
    _SPIN_PID=""
    printf "\r\033[2K"
}

usage() {
    echo -e "${PURPLE}${BOLD}feline${RESET}${BOLD} search${RESET} — fast file and app search powered by Spotlight"
    echo ""
    echo -e "${BOLD}Usage:${RESET}"
    echo "  feline search <query> [options]"
    echo ""
    echo -e "${BOLD}Options:${RESET}"
    echo "  --apps          Search applications only"
    echo "  --content       Search inside file contents"
    echo "  --dir <path>    Limit search to a specific directory"
    echo "  --type <ext>    Filter by file extension (e.g. pdf, py, mp4)"
    echo "  --limit <n>     Max results to show (default: 20)"
    echo "  --open [n]      Open result n in its default app (default: 1)"
    echo "  --reveal [n]    Reveal result n in Finder"
    echo "  --copy [n]      Copy path of result n to clipboard"
    echo ""
    echo -e "${BOLD}Examples:${RESET}"
    echo "  feline search \"budget report\""
    echo "  feline search notes --type md"
    echo "  feline search xcode --apps"
    echo "  feline search \"TODO\" --content --dir ~/Projects"
    echo "  feline search invoice --type pdf --open"
    echo "  feline search invoice --type pdf --open 2"
    exit 0
}

# File type label + icon mapping
file_label() {
    local ext="${1##*.}"
    ext="${ext,,}"
    case "$ext" in
        jpg|jpeg|png|gif|webp|heic|tiff|bmp) echo "image" ;;
        mp4|mov|avi|mkv|webm|m4v)            echo "video" ;;
        mp3|wav|flac|aac|m4a|ogg|opus)       echo "audio" ;;
        pdf)                                  echo "pdf" ;;
        doc|docx|pages)                       echo "doc" ;;
        xls|xlsx|numbers|csv)                 echo "sheet" ;;
        ppt|pptx|key)                         echo "slides" ;;
        py|js|ts|sh|c|cpp|go|rs|rb|swift|kt) echo "code" ;;
        md|txt|rtf)                           echo "text" ;;
        zip|tar|gz|bz2|rar|7z)               echo "archive" ;;
        app)                                  echo "app" ;;
        *)                                    echo "file" ;;
    esac
}

fmt_size() {
    local path="$1"
    local bytes
    bytes=$(stat -f%z "$path" 2>/dev/null || echo 0)
    if   (( bytes >= 1073741824 )); then printf "%.1f GB" "$(echo "scale=1; $bytes/1073741824" | bc)"
    elif (( bytes >= 1048576 ));    then printf "%.1f MB" "$(echo "scale=1; $bytes/1048576" | bc)"
    elif (( bytes >= 1024 ));       then printf "%.0f KB" "$(echo "scale=0; $bytes/1024" | bc)"
    else printf "%d B" "$bytes"
    fi
}

fmt_date() {
    stat -f "%Sm" -t "%b %d %Y" "$1" 2>/dev/null || echo ""
}

# ── Argument parsing ───────────────────────────────────────────────────────────
QUERY=""
APPS_ONLY=false
CONTENT=false
SEARCH_DIR=""
TYPE_FILTER=""
_cfg_limit=$(grep -E "^search\.limit=" "$HOME/.feline/config" 2>/dev/null | tail -1 | cut -d'=' -f2- || true)
LIMIT="${_cfg_limit:-20}"
ACTION=""       # open | reveal | copy
ACTION_IDX=1    # which result number to act on

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h)  usage ;;
        --apps)     APPS_ONLY=true ;;
        --content)  CONTENT=true ;;
        --dir)      shift; SEARCH_DIR="$1" ;;
        --type)     shift; TYPE_FILTER="${1,,}" ;;
        --limit)    shift; LIMIT="$1" ;;
        --open)     ACTION="open";   [[ "${2:-}" =~ ^[0-9]+$ ]] && { shift; ACTION_IDX="$1"; } ;;
        --reveal)   ACTION="reveal"; [[ "${2:-}" =~ ^[0-9]+$ ]] && { shift; ACTION_IDX="$1"; } ;;
        --copy)     ACTION="copy";   [[ "${2:-}" =~ ^[0-9]+$ ]] && { shift; ACTION_IDX="$1"; } ;;
        *)          [[ -z "$QUERY" ]] && QUERY="$1" || QUERY="$QUERY $1" ;;
    esac
    shift
done

[[ -z "$QUERY" ]] && { echo -e "${RED}Error:${RESET} no search query given."; echo "Usage: feline search <query> [options]"; exit 1; }

# ── Build mdfind command ───────────────────────────────────────────────────────
MDFIND_ARGS=()

if $CONTENT; then
    MDFIND_ARGS+=("$QUERY")
else
    MDFIND_ARGS+=("-name" "$QUERY")
fi

if $APPS_ONLY; then
    MDFIND_ARGS+=("-onlyin" "/Applications")
elif [[ -n "$SEARCH_DIR" ]]; then
    MDFIND_ARGS+=("-onlyin" "$SEARCH_DIR")
fi

# ── Run search ─────────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}search:${RESET} ${CYAN}${QUERY}${RESET}${DIM}$(${APPS_ONLY} && echo '  [apps]')$([[ -n "$TYPE_FILTER" ]] && echo "  [.$TYPE_FILTER]")${RESET}"

spin_start "searching..."
mapfile -t RESULTS < <(mdfind "${MDFIND_ARGS[@]}" 2>/dev/null)
spin_stop

# Filter by type if requested
if [[ -n "$TYPE_FILTER" ]]; then
    FILTERED=()
    for r in "${RESULTS[@]}"; do
        ext="${r##*.}"
        [[ "${ext,,}" == "$TYPE_FILTER" ]] && FILTERED+=("$r")
    done
    RESULTS=("${FILTERED[@]}")
fi

# Filter out system/hidden paths for cleaner results
CLEAN=()
for r in "${RESULTS[@]}"; do
    [[ "$r" == /System/* ]]          && continue
    [[ "$r" == /private/var/* ]]     && continue
    [[ "$r" == /usr/* ]]             && continue
    [[ "$r" == */.Spotlight-V100/* ]] && continue
    CLEAN+=("$r")
done
RESULTS=("${CLEAN[@]}")

TOTAL=${#RESULTS[@]}

if [[ $TOTAL -eq 0 ]]; then
    echo -e "${DIM}  No results found.${RESET}"
    echo ""
    exit 0
fi

echo -e "${DIM}  $TOTAL result$([ $TOTAL -ne 1 ] && echo 's') found$([ $TOTAL -gt $LIMIT ] && echo ", showing $LIMIT")${RESET}"
echo ""

SHOWN=0
INDEXED=()   # ordered list of displayed paths for --open/--reveal/--copy

for path in "${RESULTS[@]}"; do
    [[ $SHOWN -ge $LIMIT ]] && break
    [[ -e "$path" ]] || continue

    INDEXED+=("$path")
    SHOWN=$(( SHOWN + 1 ))

    label=$(file_label "$path")
    size=$(fmt_size "$path")

    # Shorten home dir
    display="${path/#$HOME/~}"
    dir=$(dirname "$display")
    name=$(basename "$display")

    # Color by type
    case "$label" in
        app)               name_color="$CYAN" ;;
        code)              name_color="$GREEN" ;;
        image|video|audio) name_color="$YELLOW" ;;
        *)                 name_color="$BOLD" ;;
    esac

    printf "  ${DIM}%2d.${RESET}  %b%-36s%b  %b%-8s%b  %b%s%b\n" \
        "$SHOWN" \
        "$name_color" "$name" "$RESET" \
        "$DIM" "$size" "$RESET" \
        "$DIM" "$dir" "$RESET"
done

if [[ $TOTAL -gt $LIMIT ]]; then
    echo ""
    echo -e "  ${DIM}… $((TOTAL - LIMIT)) more results. Use --limit to see more.${RESET}"
fi

echo ""

# ── Action (--open / --reveal / --copy) ───────────────────────────────────────
if [[ -n "$ACTION" ]]; then
    if [[ ${#INDEXED[@]} -eq 0 ]]; then
        echo -e "  ${RED}No results to act on.${RESET}\n"; exit 1
    fi
    if [[ "$ACTION_IDX" -gt ${#INDEXED[@]} ]]; then
        echo -e "  ${RED}Result ${ACTION_IDX} doesn't exist (only ${#INDEXED[@]} shown).${RESET}\n"; exit 1
    fi
    target="${INDEXED[$((ACTION_IDX - 1))]}"
    case "$ACTION" in
        open)
            echo -e "  ${CYAN}Opening${RESET} ${BOLD}$(basename "$target")${RESET}..."
            open "$target"
            ;;
        reveal)
            echo -e "  ${CYAN}Revealing in Finder:${RESET} ${DIM}${target}${RESET}"
            open -R "$target"
            ;;
        copy)
            echo -n "$target" | pbcopy
            echo -e "  ${GREEN}✓${RESET}  Path copied to clipboard: ${DIM}${target}${RESET}"
            ;;
    esac
    echo ""
elif [[ ${#INDEXED[@]} -gt 0 && -z "$ACTION" ]]; then
    echo -e "  ${DIM}Tip: add --open, --reveal, or --copy to act on a result.${RESET}\n"
fi
