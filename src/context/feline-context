#!/usr/bin/env python3
import sys
import os
import subprocess
import stat
from pathlib import Path
from datetime import datetime
from collections import defaultdict

BOLD  = '\033[1m'
GREEN = '\033[0;32m'
RED   = '\033[0;31m'
CYAN  = '\033[0;36m'
DIM   = '\033[2m'
YELLOW = '\033[1;33m'
RESET = '\033[0m'

# ── Helpers ────────────────────────────────────────────────────────────────────

def run(cmd):
    try:
        return subprocess.check_output(cmd, stderr=subprocess.DEVNULL, text=True).strip()
    except Exception:
        return ""

def mdls(path, key):
    val = run(['mdls', '-name', key, '-raw', str(path)])
    return None if val in ('(null)', '', None) else val

def fmt_size(b):
    for unit in ('B', 'KB', 'MB', 'GB', 'TB'):
        if b < 1024 or unit == 'TB':
            return f"{b:.1f} {unit}" if unit != 'B' else f"{int(b)} B"
        b /= 1024

def fmt_date(ts):
    return datetime.fromtimestamp(ts).strftime('%b %d, %Y  %I:%M %p')

def fmt_mdls_date(raw):
    try:
        return datetime.strptime(raw[:19], '%Y-%m-%d %H:%M:%S').strftime('%b %d, %Y  %I:%M %p')
    except Exception:
        return None

def rule(title="", width=56):
    if title:
        pad = max(width - len(title) - 4, 2)
        return f"{DIM}── {RESET}{BOLD}{title}{RESET}{DIM} {'─' * pad}{RESET}"
    return f"{DIM}{'─' * width}{RESET}"

def row(label, value):
    return f"  {DIM}{label:<16}{RESET}{value}"


# ── File context ───────────────────────────────────────────────────────────────

def file_context(path):
    p = Path(path).resolve()
    st = p.stat()
    ext = p.suffix.lower().lstrip('.')

    print()
    print(f"{BOLD}context:{RESET} {CYAN}{p.name}{RESET}")
    print(rule())

    # Basic
    file_type = run(['file', '--brief', str(p)])
    permissions = stat.filemode(st.st_mode)
    octal = oct(st.st_mode)[-3:]
    owner = run(['stat', '-f', '%Su', str(p)])

    print(row("Path",        str(p.parent)))
    print(row("Type",        file_type or ext.upper() or "Unknown"))
    print(row("Size",        fmt_size(st.st_size)))
    print(row("Created",     fmt_date(st.st_birthtime)))
    print(row("Modified",    fmt_date(st.st_mtime)))
    print(row("Permissions", f"{permissions}  ({octal})"))
    print(row("Owner",       owner))

    # ── Image metadata ─────────────────────────────────────────────────────────
    if ext in ('jpg','jpeg','png','gif','webp','tiff','tif','heic','heif','bmp','raw','cr2','nef','arw'):
        w      = mdls(p, 'kMDItemPixelWidth')
        h      = mdls(p, 'kMDItemPixelHeight')
        make   = mdls(p, 'kMDItemAcquisitionMake')
        model  = mdls(p, 'kMDItemAcquisitionModel')
        taken  = mdls(p, 'kMDItemContentCreationDate')
        lat    = mdls(p, 'kMDItemLatitude')
        lon    = mdls(p, 'kMDItemLongitude')
        cspace = mdls(p, 'kMDItemColorSpace')
        dpi    = mdls(p, 'kMDItemResolutionWidthDPI')

        print()
        print(rule("Image"))
        if w and h:     print(row("Dimensions",  f"{w} × {h} px"))
        if dpi:         print(row("DPI",          dpi))
        if cspace:      print(row("Color space",  cspace))
        if make or model:
            print(row("Camera", f"{make or ''} {model or ''}".strip()))
        if taken:
            d = fmt_mdls_date(taken)
            if d: print(row("Taken", d))
        if lat and lon:
            print(row("GPS", f"{float(lat):.5f}° N,  {float(lon):.5f}° E"))

    # ── Audio metadata ─────────────────────────────────────────────────────────
    elif ext in ('mp3','wav','flac','aac','m4a','ogg','opus','aiff','wma'):
        duration    = mdls(p, 'kMDItemDurationSeconds')
        bitrate     = mdls(p, 'kMDItemAudioBitRate')
        sample_rate = mdls(p, 'kMDItemAudioSampleRate')
        channels    = mdls(p, 'kMDItemAudioChannelCount')
        title       = mdls(p, 'kMDItemTitle')
        artists     = mdls(p, 'kMDItemAuthors')
        album       = mdls(p, 'kMDItemAlbum')

        print()
        print(rule("Audio"))
        if title:   print(row("Title",       title))
        if artists:
            # mdls returns ("Artist Name") — strip parens and quotes
            clean = artists.strip('()').replace('"', '').strip().strip(',').strip()
            print(row("Artist", clean))
        if album:   print(row("Album",       album))
        if duration:
            s = float(duration)
            print(row("Duration", f"{int(s//60)}:{int(s%60):02d}"))
        if bitrate:     print(row("Bitrate",     f"{int(float(bitrate))//1000} kbps"))
        if sample_rate: print(row("Sample rate", f"{int(float(sample_rate)):,} Hz"))
        if channels:    print(row("Channels",    channels))

    # ── Video metadata ─────────────────────────────────────────────────────────
    elif ext in ('mp4','mov','avi','mkv','webm','m4v','flv'):
        duration = mdls(p, 'kMDItemDurationSeconds')
        codecs   = mdls(p, 'kMDItemCodecs')
        w        = mdls(p, 'kMDItemPixelWidth')
        h        = mdls(p, 'kMDItemPixelHeight')
        fps      = mdls(p, 'kMDItemVideoFrameRate')

        print()
        print(rule("Video"))
        if w and h:  print(row("Resolution", f"{w} × {h}"))
        if fps:      print(row("Frame rate", f"{float(fps):.2f} fps"))
        if duration:
            s = float(duration)
            print(row("Duration", f"{int(s//60)}:{int(s%60):02d}"))
        if codecs:
            clean = codecs.strip('()').replace('"', '').replace(',\n', ' · ').replace('\n', '').strip()
            print(row("Codecs", clean))

    # ── Document metadata ──────────────────────────────────────────────────────
    elif ext in ('pdf','docx','doc','pptx','ppt','xlsx','xls','odt','pages','numbers','key'):
        pages   = mdls(p, 'kMDItemNumberOfPages')
        title   = mdls(p, 'kMDItemTitle')
        authors = mdls(p, 'kMDItemAuthors')
        comment = mdls(p, 'kMDItemComment')

        print()
        print(rule("Document"))
        if title:   print(row("Title",   title))
        if authors:
            clean = authors.strip('()').replace('"', '').strip().strip(',').strip()
            print(row("Authors", clean))
        if pages:   print(row("Pages",   pages))
        if comment: print(row("Comment", comment))

    # ── Code / text preview ────────────────────────────────────────────────────
    elif ext in ('py','js','ts','jsx','tsx','sh','bash','zsh','c','h','cpp','cc',
                 'go','rs','rb','swift','kt','java','css','scss','html','htm',
                 'md','txt','json','yaml','yml','toml','xml','csv','sql'):
        try:
            with open(p, 'r', errors='ignore') as f:
                lines = f.readlines()
            line_count = len(lines)
            word_count = sum(len(l.split()) for l in lines)
            char_count = sum(len(l) for l in lines)

            print()
            print(rule("Content"))
            print(row("Lines",      f"{line_count:,}"))
            print(row("Words",      f"{word_count:,}"))
            print(row("Characters", f"{char_count:,}"))

            preview = [l.rstrip() for l in lines if l.strip()][:5]
            if preview:
                print()
                print(f"  {DIM}Preview:{RESET}")
                for line in preview:
                    truncated = (line[:74] + '…') if len(line) > 75 else line
                    print(f"  {DIM}│{RESET} {truncated}")
        except Exception:
            pass

    # ── Git info ───────────────────────────────────────────────────────────────
    git_log = run(['git', '-C', str(p.parent), 'log', '--oneline', '-1', '--', str(p)])
    if git_log:
        git_status = run(['git', '-C', str(p.parent), 'status', '--short', str(p)])
        print()
        print(rule("Git"))
        print(row("Last commit", git_log))
        if git_status:
            print(row("Status", git_status.strip()))

    # ── References ─────────────────────────────────────────────────────────────
    ref_out = run(['grep', '-rl', p.name, str(p.parent),
                   '--include=*.py', '--include=*.js', '--include=*.ts',
                   '--include=*.sh', '--include=*.md', '--include=*.json',
                   '--include=*.yaml', '--include=*.yml', '--include=*.toml',
                   '--include=*.html', '--include=*.css'])
    ref_files = [r for r in ref_out.splitlines() if r != str(p)]

    print()
    print(rule("References"))
    if ref_files:
        for ref in ref_files[:6]:
            rel = os.path.relpath(ref, p.parent)
            print(f"  {DIM}↳{RESET} {rel}")
        if len(ref_files) > 6:
            print(f"  {DIM}  … and {len(ref_files) - 6} more{RESET}")
    else:
        print(f"  {DIM}No references found nearby.{RESET}")

    print()


# ── Directory context ──────────────────────────────────────────────────────────

def dir_context(path):
    p = Path(path).resolve()
    st = p.stat()

    print()
    print(f"{BOLD}context:{RESET} {CYAN}{p.name}/{RESET}")
    print(rule())

    total_kb  = int((run(['du', '-sk', str(p)]) or '0').split()[0])
    all_items = list(p.rglob('*'))
    files     = [f for f in all_items if f.is_file()]
    dirs_     = [f for f in all_items if f.is_dir()]
    owner     = run(['stat', '-f', '%Su', str(p)])
    perms     = stat.filemode(st.st_mode)
    octal     = oct(st.st_mode)[-3:]

    print(row("Path",        str(p)))
    print(row("Size",        fmt_size(total_kb * 1024)))
    print(row("Contents",    f"{len(files)} files,  {len(dirs_)} directories"))
    print(row("Modified",    fmt_date(st.st_mtime)))
    print(row("Permissions", f"{perms}  ({octal})"))
    print(row("Owner",       owner))

    # By file type
    ext_stats = defaultdict(lambda: {'count': 0, 'size': 0})
    for f in files:
        key = f.suffix.lower() or '(none)'
        ext_stats[key]['count'] += 1
        try:
            ext_stats[key]['size'] += f.stat().st_size
        except Exception:
            pass

    if ext_stats:
        print()
        print(rule("By type"))
        for ext, info in sorted(ext_stats.items(), key=lambda x: x[1]['size'], reverse=True)[:8]:
            n = info['count']
            print(f"  {DIM}{ext:<14}{RESET}  {n:>4} file{'s' if n != 1 else ''}   {fmt_size(info['size'])}")

    # Stat each file once, tolerating files that vanish mid-scan
    stats = []
    for f in files:
        try:
            stats.append((f, f.stat()))
        except OSError:
            pass

    # Largest files
    sized = sorted(stats, key=lambda x: x[1].st_size, reverse=True)
    if sized:
        print()
        print(rule("Largest files"))
        for f, st_f in sized[:5]:
            rel = os.path.relpath(f, p)
            print(f"  {DIM}{fmt_size(st_f.st_size):>10}{RESET}  {rel}")

    # Recently modified
    recent = sorted(stats, key=lambda x: x[1].st_mtime, reverse=True)[:5]
    if recent:
        print()
        print(rule("Recently modified"))
        for f, st_f in recent:
            rel   = os.path.relpath(f, p)
            mtime = fmt_date(st_f.st_mtime)
            print(f"  {DIM}{mtime}{RESET}   {rel}")

    # Git
    git_branch = run(['git', '-C', str(p), 'branch', '--show-current'])
    if git_branch:
        git_log    = run(['git', '-C', str(p), 'log', '--oneline', '-3'])
        git_status = run(['git', '-C', str(p), 'status', '--short'])
        changed    = len(git_status.splitlines()) if git_status else 0

        print()
        print(rule("Git"))
        print(row("Branch",      git_branch))
        if changed:
            print(row("Uncommitted", f"{changed} file{'s' if changed != 1 else ''} changed"))
        if git_log:
            print(f"  {DIM}Recent commits:{RESET}")
            for line in git_log.splitlines():
                print(f"  {DIM}│{RESET} {line}")

    print()


# ── Entry point ────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 2 or sys.argv[1] in ('--help', '-h'):
        print(f"{BOLD}feline context{RESET} — detailed info and metadata for any file or directory")
        print()
        print(f"{BOLD}Usage:{RESET}")
        print("  feline context <file-or-directory>")
        print()
        print(f"{BOLD}Examples:{RESET}")
        print("  feline context photo.jpg")
        print("  feline context song.mp3")
        print("  feline context notes.md")
        print("  feline context ~/Projects/myapp")
        sys.exit(0)

    target = sys.argv[1]

    if not os.path.exists(target):
        print(f"{RED}Error:{RESET} not found: {target}", file=sys.stderr)
        sys.exit(1)

    if os.path.isdir(target):
        dir_context(target)
    else:
        file_context(target)


if __name__ == '__main__':
    main()
